## ── MercadoLibre ─────────────────────────────────────────────
# Token de usuario OAuth (APP_USR-...) — obtener en developers.mercadolibre.com.ar
MELI_ACCESS_TOKEN=APP_USR-...

# Opcional: credenciales de app para renovar token automáticamente
ML_APP_ID=
ML_APP_SECRET=

## ── Anthropic (Claude API) ───────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

## ── Shopify ──────────────────────────────────────────────────
# Tu dominio Shopify (sin https://)
SHOPIFY_STORE_URL=mitienda.myshopify.com
# Admin → Apps → Desarrollar apps → token con permiso write_content
SHOPIFY_ACCESS_TOKEN=shpat_...

## ── fal.ai (generación de video) ────────────────────────────
# fal.ai → Dashboard → API Keys
FAL_KEY=...

## ── Configuración del pipeline ───────────────────────────────
TRENDS_GEO=CO
SCORE_THRESHOLD=60
VIDEO_VARIATIONS=3
